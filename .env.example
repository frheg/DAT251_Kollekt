# Copy to .env and fill in real values. NEVER commit the real .env.
# These are placeholders only — no secrets belong in this file.

# --- Database (PostgreSQL / Supabase) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change-me

# --- Flyway ---
SPRING_FLYWAY_ENABLED=true
SPRING_FLYWAY_LOCATIONS=classpath:db/migration

# --- Security ---
# Must be at least 32 characters.
APP_SECURITY_JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# --- CORS ---
# Comma-separated. Include the web origin and the Capacitor app origins.
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,capacitor://localhost,http://localhost

# --- Google OAuth (Calendar) ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/google-calendar/callback
GOOGLE_FRONTEND_URL=http://localhost:5173
GOOGLE_MOBILE_RETURN_URL=no.kollekt.app://google-calendar-connected

# --- Frontend (web build) ---
# Leave VITE_API_URL relative for the web/nginx deployment; the mobile build
# overrides it with an absolute HTTPS URL via .env.mobile.
VITE_API_URL=http://localhost:8080/api

# --- Kollekt Games service ---
VITE_GAMES_API_URL=http://localhost:4000/api
# NOTE: anything compiled into the bundle is PUBLIC, not a secret.
VITE_GAMES_API_KEY=dev-key
