# Copy to .env.mobile and fill in real values. NEVER commit the real .env.mobile.
# Loaded by `vite build --mode mobile` (npm run mobile:sync / build:mobile).
# Both URLs MUST be absolute https:// — a phone cannot reach localhost, and the
# build refuses non-HTTPS URLs.

# Deployed Kotlin backend, including the /api path. WSS realtime is derived from this origin.
VITE_API_URL=https://your-backend-host/api

# Deployed Kollekt Games service, including its /api path.
VITE_GAMES_API_URL=https://your-games-host/api

# Games API key. NOTE: compiled into the bundle = PUBLIC, not a secret.
# Stopgap until the games service adopts public-client auth (see plan.md release gate).
VITE_GAMES_API_KEY=your-games-api-key
